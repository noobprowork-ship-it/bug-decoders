            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/activity/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activities\": [\n    { \"name\": \"deep work\", \"hoursPerWeek\": 18 },\n    { \"name\": \"gaming\", \"hoursPerWeek\": 8 }\n  ],\n  \"skills\": [\"writing\", \"systems design\"],\n  \"ambitions\": [\"ship Aurora MVP\"]\n}"
            }
