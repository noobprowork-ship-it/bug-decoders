{
  "info": {
    "name": "Aurora Mind OS — Backend",
    "_postman_id": "aurora-mind-os-backend",
    "description": "All 13 features of the Aurora Mind OS backend API. Set the `baseUrl` and `token` collection variables. After /auth/login, copy the returned token into the `token` variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "GET /api/health", "request": { "method": "GET", "url": "{{baseUrl}}/api/health" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Amit\",\n  \"email\": \"amit@example.com\",\n  \"password\": \"AuroraTest!42\"\n}"
            }
          }
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"amit@example.com\",\n  \"password\": \"AuroraTest!42\"\n}"
            }
          }
        },
        {
          "name": "POST /api/auth/voice-login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/voice-login",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "amit@example.com", "type": "text" },
                { "key": "audio", "type": "file", "src": [] }
              ]
            }
          }
        },
        { "name": "GET /api/auth/me", "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" } }
      ]
    },
    {
      "name": "AI Chat",
      "item": [
        {
          "name": "POST /api/ai/chat",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai/chat",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [{ \"role\": \"user\", \"content\": \"What should I focus on this week?\" }]\n}"
            }
          }
        },
        { "name": "GET /api/ai/sessions", "request": { "method": "GET", "url": "{{baseUrl}}/api/ai/sessions" } }
      ]
    },
    {
      "name": "Command Center",
      "item": [
        {
          "name": "POST /api/command-center/plan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/command-center/plan",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goals\": [\"Ship Aurora MVP\", \"Run 5km\"],\n  \"currentChallenges\": [\"Sleep\"],\n  \"timeAvailableHoursPerDay\": 4,\n  \"mood\": \"focused\"\n}"
            }
          }
        },
        { "name": "GET /api/command-center/latest", "request": { "method": "GET", "url": "{{baseUrl}}/api/command-center/latest" } }
      ]
    },
