# =====================================================================
# Aurora backend — environment variables
# Copy this file to backend/.env and fill in real values.
#   cp backend/.env.example backend/.env
# The server boots even when these are missing — it logs warnings and
# AI / DB calls fail with clear errors. Set them for full functionality.
# =====================================================================

# --- HTTP server ---
PORT=3001
HOST=localhost

# Comma-separated list of allowed browser origins. Leave blank to allow all.
# Example for local dev: FRONTEND_URL=http://localhost:5000
FRONTEND_URL=

# --- MongoDB ---
# Local example:    mongodb://localhost:27017/aurora
# Atlas example:    mongodb+srv://<user>:<pass>@<cluster>/aurora
MONGODB_URI=

# --- JWT ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- OpenAI ---
# Required for: AI chat, voice login (Whisper), all 13 AI features.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
